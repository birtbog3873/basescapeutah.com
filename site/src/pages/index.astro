---
import BaseLayout from '../layouts/BaseLayout.astro'
import CTABlock from '../components/content/CTABlock.astro'
import ServiceCard from '../components/content/ServiceCard.astro'
import TrustBadges from '../components/trust/TrustBadges.astro'
import ReviewCard from '../components/trust/ReviewCard.astro'
import JsonLd from '../components/seo/JsonLd.astro'
import {
  generateOrganizationSchema,
  generateLocalBusinessSchema,
} from '../lib/schema'
import {
  fetchServices,
  fetchReviews,
  fetchSiteSettings,
  resolveServiceImage,
} from '../lib/payload'

let services: any[] = []
let reviews: any[] = []
let settings: any = {
  businessName: 'BaseScape',
  phone: '(888) 414-0007',
  email: 'hello@basescapeutah.com',
  address: { street: '123 Innovation Way', city: 'Draper', state: 'UT', zip: '84020' },
  operatingHours: [
    { day: 'Mon', open: '08:00', close: '18:00' },
    { day: 'Tue', open: '08:00', close: '18:00' },
    { day: 'Wed', open: '08:00', close: '18:00' },
    { day: 'Thu', open: '08:00', close: '18:00' },
    { day: 'Fri', open: '08:00', close: '18:00' },
    { day: 'Sat', open: '09:00', close: '14:00' },
  ],
  licenseNumber: '14082066-5501 B100',
  insuranceInfo: 'Fully Insured & Bonded — General Liability',
  riskReversals: [
    { statement: 'Free Written Estimates' },
    { statement: 'No Hidden Charges' },
    { statement: 'Dust Containment System' },
  ],
}

try {
  const [servicesRes, reviewsRes, siteSettings] = await Promise.all([
    fetchServices(),
    fetchReviews(),
    fetchSiteSettings(),
  ])
  services = (servicesRes.docs || []).map((s: any) => ({
    ...s,
    heroImage: resolveServiceImage(s.slug, 'card', s.heroImage),
  }))
  reviews = (reviewsRes.docs || []).filter((r: any) => r.featured)
  settings = { ...settings, ...siteSettings }
} catch {
  // Use fallback data for static build without CMS
  services = [
    { title: 'Walkout Basements', tagline: 'Transform your basement into a light-filled walkout with direct landscape access.', slug: 'walkout-basements', primaryValuePillar: 'financial', heroImage: { url: '/images/services/card-walkout-basements.webp', alt: 'Close-up of a completed walkout basement entry showing sliding glass doors, concrete landing, and stone retaining walls' } },
    { title: 'Basement Remodeling', tagline: 'Full basement transformations that convert dark, underutilized space into premium living areas.', slug: 'basement-remodeling', primaryValuePillar: 'transformation', heroImage: { url: '/images/services/card-basement-remodeling.webp', alt: 'Finished basement living area with exterior entry door and large egress window flooding the space with natural light' } },
    { title: 'Pavers & Hardscapes', tagline: 'Custom paver patios, walkways, and hardscape installations that extend your living space outdoors.', slug: 'pavers-hardscapes', primaryValuePillar: 'transformation', heroImage: { url: '/images/services/card-pavers-hardscapes.webp', alt: 'Interlocking paver patio with bistro dining set extending from a Utah home, Wasatch foothills in the background' } },
    { title: 'Retaining Walls', tagline: 'Engineered retaining wall systems that manage slopes, prevent erosion, and create usable outdoor space.', slug: 'retaining-walls', primaryValuePillar: 'transformation', heroImage: { url: '/images/services/card-retaining-walls.webp', alt: 'Tiered stone retaining walls with landscaping creating usable flat outdoor space in a sloped Utah backyard' } },
    { title: 'Artificial Turf', tagline: 'Low-maintenance, year-round green spaces that save water and eliminate mowing.', slug: 'artificial-turf', primaryValuePillar: 'transformation', heroImage: { url: '/images/services/card-artificial-turf.webp', alt: 'Vibrant green artificial turf lawn with paver borders and a dog playing in a fenced Utah backyard' } },
    { title: 'Egress Windows', tagline: 'Code-compliant emergency exit windows that flood basements with natural light.', slug: 'egress-windows', primaryValuePillar: 'safety', heroImage: { url: '/images/services/card-egress-windows.webp', alt: 'Exterior view of an upgraded egress window well with stone veneer liner and river rock' } },
  ]
}

const phone = settings.phone
const orgSchema = generateOrganizationSchema(settings)
const localSchema = generateLocalBusinessSchema(settings, {
  aggregateRating: reviews.length > 0
    ? {
        ratingValue: reviews.reduce((sum: number, r: any) => sum + r.starRating, 0) / reviews.length,
        reviewCount: reviews.length,
      }
    : undefined,
  servicesOffered: services.map((s: any) => s.title),
})
---
<BaseLayout title="Home">
  <JsonLd slot="head" schema={[orgSchema, localSchema]} />

  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__content">
        <span class="hero__overline">Utah's Wasatch Front</span>
        <h1 class="hero__title">
          Your Basement Has a
          <span class="hero__highlight">Better Future</span>
        </h1>
        <p class="hero__subtitle">
          Licensed, insured, and trusted by Wasatch Front homeowners. We handle everything — design, permits, and build — so you don't have to.
        </p>
        <form class="hero__zip-form" method="GET" action="/contact">
          <label for="hero-zip" class="sr-only">Enter your ZIP code</label>
          <input
            id="hero-zip"
            type="text"
            name="zip"
            inputmode="numeric"
            maxlength="5"
            pattern="[0-9]{5}"
            placeholder="ZIP Code"
            required
            class="hero__zip-input"
          />
          <button type="submit" class="hero__zip-btn">Schedule a Free Design</button>
        </form>
      </div>
      <div class="hero__visual">
        <img
          class="hero__image"
          src="/images/services/hero-homepage.webp"
          alt="Completed walkout basement on a Utah home — sliding glass doors open to an inviting patio with stone retaining walls, green lawn above, and Wasatch mountains in the distance"
          width="1200"
          height="805"
        />
      </div>
    </div>
  </section>

  <!-- Trust Badges (above fold per FR-028) -->
  <section class="trust-section">
    <div class="trust-section__inner">
      <TrustBadges
        licenseNumber={settings.licenseNumber}
        insuranceInfo={settings.insuranceInfo}
        riskReversals={settings.riskReversals}
      />
    </div>
  </section>

  <!-- Services Overview -->
  <section class="services-section">
    <div class="services-section__inner">
      <h2 class="section-heading">Our Specialized Services</h2>
      <p class="section-lead">
        We focus exclusively on basement access and egress — it's all we do, and we do it exceptionally well.
      </p>
      <div class="services-grid">
        {services.map((service: any) => (
          <ServiceCard
            title={service.title}
            tagline={service.tagline}
            slug={service.slug}
            valuePillar={service.primaryValuePillar}
            heroImage={service.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Reviews (hidden when showReviews is false) -->
  {settings.showReviews && reviews.length > 0 && (
    <section class="reviews-section">
      <div class="reviews-section__inner">
        <h2 class="section-heading">What Homeowners Say</h2>
        <div class="reviews-grid">
          {reviews.slice(0, 3).map((review: any) => (
            <ReviewCard
              reviewerName={review.reviewerName}
              reviewText={review.reviewText}
              starRating={review.starRating}
              city={review.city?.cityName}
              source={review.source}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="final-cta-section">
    <div class="final-cta-section__inner">
      <CTABlock
        headline="Ready to Transform Your Basement?"
        phone={phone}
        variant="section"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-bgPage) 0%, var(--color-bgAlt) 100%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-7);
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--size-8) var(--size-4);
  }

  @media (min-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: var(--size-10) var(--size-6);
      gap: var(--size-9);
    }
  }

  .hero__overline {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal500);
    margin-bottom: var(--size-2);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: clamp(2.5rem, 5vw + 1rem, 4rem);
    line-height: 1.1;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-4);
  }

  .hero__highlight {
    color: var(--color-green500);
  }

  .hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 0.5vw + 0.875rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-textBody);
    margin-bottom: var(--size-6);
    max-width: 540px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .hero__zip-form {
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
    max-width: 400px;
  }

  @media (min-width: 480px) {
    .hero__zip-form {
      flex-direction: row;
    }
  }

  .hero__zip-input {
    padding: var(--size-3) var(--size-4);
    font-family: var(--font-sans);
    font-size: 1rem;
    border: 2px solid var(--color-navy200);
    border-radius: var(--radius-md);
    background: var(--color-bgSurface);
    color: var(--color-textPrimary);
    min-height: 48px;
    width: 120px;
    flex-shrink: 0;
  }

  .hero__zip-input:focus {
    outline: none;
    border-color: var(--color-teal500);
  }

  .hero__zip-btn {
    padding: var(--size-3) var(--size-5);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.03em;
    background: var(--color-ctaPrimaryBg);
    color: var(--color-ctaPrimaryText);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    min-height: 48px;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .hero__zip-btn:hover {
    background: var(--color-ctaPrimaryHover);
  }

  .hero__visual {
    display: none;
  }

  @media (min-width: 768px) {
    .hero__visual { display: block; }
  }

  .hero__image {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .trust-section {
    padding: var(--size-5) 0;
  }

  .trust-section__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  @media (min-width: 768px) {
    .trust-section__inner {
      padding-inline: var(--size-6);
    }
  }

  .services-section,
  .reviews-section {
    padding: var(--size-8) 0;
  }

  @media (min-width: 768px) {
    .services-section,
    .reviews-section {
      padding: var(--size-10) 0;
    }
  }

  .reviews-section {
    background: var(--color-bgAlt);
  }

  .services-section__inner,
  .reviews-section__inner,
  .final-cta-section__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  @media (min-width: 768px) {
    .services-section__inner,
    .reviews-section__inner,
    .final-cta-section__inner {
      padding-inline: var(--size-6);
    }
  }

  .section-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: clamp(1.625rem, 2vw + 0.5rem, 2.25rem);
    line-height: 1.2;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-2);
  }

  .section-lead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.5vw + 0.75rem, 1.125rem);
    color: var(--color-textBody);
    margin-bottom: var(--size-6);
    max-width: 600px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-5);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-5);
  }

  @media (min-width: 768px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .final-cta-section {
    padding: var(--size-8) 0 var(--size-10);
  }
</style>
