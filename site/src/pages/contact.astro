---
import BaseLayout from '../layouts/BaseLayout.astro'
import MultiStepForm from '../components/forms/MultiStepForm.tsx'
import TrustBadges from '../components/trust/TrustBadges.astro'
import { fetchSiteSettings } from '../lib/payload'

let settings: any = {
  businessName: 'BaseScape',
  phone: '(801) 919-8224',
  licenseNumber: '14082066-5501 B100',
  insuranceInfo: 'Fully Insured & Bonded — General Liability',
  riskReversals: [
    { statement: 'Free Written Estimates' },
    { statement: 'No Hidden Charges' },
    { statement: 'Dust Containment System' },
  ],
}

try {
  const siteSettings = await fetchSiteSettings()
  settings = { ...settings, ...siteSettings }
} catch {
  // Use hardcoded fallbacks (Constitution I)
}

const phone = settings.phone
const phoneClean = phone.replace(/[^\d+]/g, '')
---
<BaseLayout
  title="Contact Us"
  description="Schedule your free basement or hardscape estimate. BaseScape serves Utah's Wasatch Front — licensed, insured, and ready to transform your property."
  hideEstimate
>
  <section class="contact-hero">
    <div class="contact-hero__inner">
      <h1 class="contact-hero__title">Get Your Free Estimate</h1>
      <p class="contact-hero__subtitle">
        Tell us about your project and a BaseScape specialist will call you within 24 hours.
      </p>
    </div>
  </section>

  <section class="contact-form-section" id="form">
    <div class="contact-form-section__inner">
      <MultiStepForm client:load sourcePage="/contact" phone={phone} />
    </div>
  </section>

  <section class="contact-trust-section">
    <div class="contact-trust-section__inner">
      <TrustBadges
        licenseNumber={settings.licenseNumber}
        insuranceInfo={settings.insuranceInfo}
        riskReversals={settings.riskReversals}
      />
    </div>
  </section>

  <section class="contact-call-section">
    <div class="contact-call-section__inner">
      <p class="contact-call-section__text">Prefer to call?</p>
      <a href={`tel:${phoneClean}`} class="contact-call-section__btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phone}
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  // Auto-scroll to the form when landing on the contact page
  // Use requestAnimationFrame to wait for React hydration
  requestAnimationFrame(() => {
    const formSection = document.getElementById('form')
    if (formSection) {
      formSection.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }
  })
</script>

<style>
  .contact-hero {
    background: linear-gradient(180deg, var(--color-bgPage) 0%, var(--color-bgAlt) 100%);
    padding: var(--size-8) 0 var(--size-4);
    text-align: center;
  }

  .contact-hero__inner {
    max-width: 600px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  .contact-hero__title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    line-height: 1.1;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-3);
  }

  .contact-hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 0.5vw + 0.875rem, 1.1875rem);
    line-height: 1.6;
    color: var(--color-textBody);
  }

  .contact-form-section {
    padding: var(--size-6) 0;
    scroll-margin-top: var(--size-2);
  }

  .contact-form-section__inner {
    max-width: 600px;
    margin-inline: auto;
    padding-inline: var(--size-2);
  }

  @media (min-width: 480px) {
    .contact-form-section__inner {
      padding-inline: var(--size-4);
    }
  }

  .contact-trust-section {
    padding: var(--size-4) 0;
  }

  .contact-trust-section__inner {
    max-width: 600px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  .contact-call-section {
    padding: var(--size-6) 0 var(--size-8);
    text-align: center;
  }

  .contact-call-section__inner {
    max-width: 600px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  .contact-call-section__text {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-textBody);
    margin-bottom: var(--size-3);
  }

  .contact-call-section__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
    padding: var(--size-3) var(--size-6);
    background: var(--color-ctaSecondaryBg);
    color: var(--color-ctaSecondaryText);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    border-radius: var(--radius-md);
    min-height: 48px;
    transition: background 0.15s ease;
  }

  .contact-call-section__btn:hover {
    background: var(--color-ctaSecondaryHover);
  }
</style>
