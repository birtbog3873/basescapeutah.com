---
import BaseLayout from '../layouts/BaseLayout.astro'
import CTABlock from '../components/content/CTABlock.astro'
import { fetchSiteSettings } from '../lib/payload'

let settings: any = { phone: '(888) 414-0007', businessName: 'BaseScape', email: 'hello@basescapeutah.com' }
try { settings = { ...settings, ...(await fetchSiteSettings()) } } catch {}
const phone = settings.phone

const steps = [
  {
    number: 1,
    title: 'Free Consultation',
    description:
      'We visit your property, assess your basement and soil conditions, and discuss your goals. No pressure, no obligation — just honest guidance from specialists who do this every day.',
  },
  {
    number: 2,
    title: 'Custom Proposal',
    description:
      'Within 48 hours you receive a detailed written estimate — no hidden charges. Every line item is explained so you know exactly what you are paying for and why.',
  },
  {
    number: 3,
    title: 'Engineering & Permits',
    description:
      'We handle all structural engineering plans, city permits, and code compliance. You never have to visit a government office or chase down paperwork.',
  },
  {
    number: 4,
    title: 'Site Preparation',
    description:
      'Our dust containment system and protective measures keep your home clean. We seal off the work area and protect your floors, walls, and furnishings before any cutting begins.',
  },
  {
    number: 5,
    title: 'Precision Excavation',
    description:
      'Specialized equipment and our surgical extraction protocol protect your foundation. Every cut is guided by the structural engineering plan — measured twice, cut once.',
  },
  {
    number: 6,
    title: 'Finishing & Inspection',
    description:
      'Final grading, drainage, concrete, and code inspection — backed by our workmanship guarantee. We do not consider the job done until the inspector signs off and you are completely satisfied.',
  },
]
---

<BaseLayout
  title="How It Works"
  description="Our six-step process takes your basement project from free consultation through final inspection. Engineering-first approach, no hidden charges, and a workmanship guarantee on every job."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <span class="hero__overline">Our Process</span>
      <h1 class="hero__title">
        How It
        <span class="hero__highlight">Works</span>
      </h1>
      <p class="hero__subtitle">
        From the first phone call to the final inspection, we follow a proven six-step
        process designed to protect your home, your budget, and your peace of mind.
        Every project is backed by structural engineering and our workmanship guarantee.
      </p>
      <CTABlock variant="hero" phone={phone} />
    </div>
  </section>

  <!-- Steps -->
  <section class="section">
    <div class="section__inner">
      <h2 class="section-heading">Six Steps to a Transformed Basement</h2>
      <p class="section-lead">
        Our engineering-first approach means every detail is planned before work begins.
        Here is exactly what to expect.
      </p>
      <ol class="steps" role="list">
        {steps.map((step) => (
          <li class="step">
            <div class="step__number" aria-hidden="true">{step.number}</div>
            <div class="step__content">
              <h3 class="step__title">{step.title}</h3>
              <p class="step__description">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Trust / Why This Process -->
  <section class="section section--alt">
    <div class="section__inner">
      <h2 class="section-heading">Why Our Process Matters</h2>
      <p class="section-lead">
        Cutting into a foundation wall is structural engineering, not general carpentry.
        Our process reflects that reality at every step.
      </p>
      <div class="trust-grid">
        <div class="trust-card">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="trust-card__title">Engineering First</h3>
          <p class="trust-card__text">
            Every opening is designed by a licensed structural engineer before we pick up a saw.
            No guesswork, no shortcuts.
          </p>
        </div>
        <div class="trust-card">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <h3 class="trust-card__title">Transparent Pricing</h3>
          <p class="trust-card__text">
            Your written estimate details every cost. No surprise charges, no vague allowances.
            The price we quote is the price you pay.
          </p>
        </div>
        <div class="trust-card">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3 class="trust-card__title">Code Compliant</h3>
          <p class="trust-card__text">
            We pull all permits, schedule every required inspection, and ensure your project
            meets or exceeds Utah building codes.
          </p>
        </div>
        <div class="trust-card">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3 class="trust-card__title">Clean Jobsite</h3>
          <p class="trust-card__text">
            Our dust containment system and daily cleanup protocol mean you can live in your home
            comfortably throughout the project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Callout -->
  <section class="section">
    <div class="section__inner">
      <div class="timeline-callout">
        <div class="timeline-callout__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <div>
          <p class="timeline-callout__title">Typical Project Timeline</p>
          <p class="timeline-callout__text">
            Most basement walkout and egress projects are completed within 2 to 4 weeks from the
            start of on-site work. Engineering and permitting typically take an additional 1 to 3
            weeks before construction begins — we keep you informed at every milestone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section--alt">
    <div class="section__inner">
      <CTABlock
        headline="Ready to Start with a Free Consultation?"
        phone={phone}
        variant="section"
      />
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(180deg, var(--color-bgPage) 0%, var(--color-bgAlt) 100%);
  }

  .hero__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--size-8) var(--size-4);
  }

  @media (min-width: 768px) {
    .hero__inner {
      padding: var(--size-10) var(--size-6);
      max-width: 800px;
    }
  }

  .hero__overline {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal500);
    margin-bottom: var(--size-2);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: clamp(2.5rem, 5vw + 1rem, 4rem);
    line-height: 1.1;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-4);
  }

  .hero__highlight {
    color: var(--color-green500);
  }

  .hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 0.5vw + 0.875rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-textBody);
    margin-bottom: var(--size-6);
    max-width: 600px;
  }

  /* Sections */
  .section {
    padding: var(--size-8) 0;
  }

  @media (min-width: 768px) {
    .section {
      padding: var(--size-10) 0;
    }
  }

  .section--alt {
    background: var(--color-bgAlt);
  }

  .section__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  @media (min-width: 768px) {
    .section__inner {
      padding-inline: var(--size-6);
    }
  }

  .section-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: clamp(1.625rem, 2vw + 0.5rem, 2.25rem);
    line-height: 1.2;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-2);
  }

  .section-lead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.5vw + 0.75rem, 1.125rem);
    color: var(--color-textBody);
    margin-bottom: var(--size-6);
    max-width: 600px;
  }

  /* Steps */
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-5);
  }

  @media (min-width: 768px) {
    .steps {
      gap: var(--size-6);
    }
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--size-4);
    background: var(--color-bgSurface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--size-5);
  }

  @media (min-width: 768px) {
    .step {
      padding: var(--size-6);
    }
  }

  .step__number {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--color-navy600);
    color: var(--color-white);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .step__content {
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .step__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-textPrimary);
  }

  .step__description {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-textBody);
    margin: 0;
  }

  /* Trust Grid */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-5);
  }

  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .trust-card {
    padding: var(--size-5);
    background: var(--color-bgSurface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .trust-card__icon {
    color: var(--color-navy600);
    margin-bottom: var(--size-3);
  }

  .trust-card__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-2);
  }

  .trust-card__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-textBody);
    margin: 0;
  }

  /* Timeline Callout */
  .timeline-callout {
    display: flex;
    align-items: flex-start;
    gap: var(--size-4);
    padding: var(--size-5);
    background: var(--color-bgSurface);
    border: 1px solid var(--color-green200);
    border-left: 4px solid var(--color-green500);
    border-radius: var(--radius-md);
  }

  .timeline-callout__icon {
    flex-shrink: 0;
    color: var(--color-green500);
    margin-top: 2px;
  }

  .timeline-callout__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: 1.125rem;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-1);
  }

  .timeline-callout__text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-textBody);
  }
</style>
