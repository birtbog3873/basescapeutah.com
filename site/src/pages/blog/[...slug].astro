---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CTABlock from '../../components/content/CTABlock.astro'
import LeadMagnetCTA from '../../components/content/LeadMagnetCTA.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { generateArticleSchema, generateBreadcrumbSchema } from '../../lib/schema'
import { fetchBlogPosts, fetchSiteSettings } from '../../lib/payload'
import { serializeLexical } from '../../lib/serialize-lexical'

export async function getStaticPaths() {
  let posts: any[] = []
  try {
    const res = await fetchBlogPosts()
    posts = res.docs || []
  } catch {
    posts = []
  }

  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props

let settings: any = { phone: '(888) 414-0007', businessName: 'BaseScape' }
try {
  settings = { ...settings, ...(await fetchSiteSettings()) }
} catch {}

const phone = settings.phone

const categoryLabels: Record<string, string> = {
  'walkout-basements': 'Walkout Basements',
  'egress-windows': 'Egress Windows',
  'basement-remodeling': 'Basement Remodeling',
  'retaining-walls': 'Retaining Walls',
  'adu-compliance': 'ADU Compliance',
  'financing': 'Financing',
  'local-guides': 'Local Guides',
  'safety': 'Safety',
}

const articleSchema = generateArticleSchema({
  headline: post.title,
  author: post.author || 'BaseScape',
  publishDate: post.publishDate,
  image: post.heroImage?.url,
  description: post.excerpt,
  url: `https://basescapeutah.com/blog/${post.slug}`,
})

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://basescapeutah.com' },
  { name: 'Blog', url: 'https://basescapeutah.com/blog' },
  { name: post.title, url: `https://basescapeutah.com/blog/${post.slug}` },
])

const relatedServices = post.relatedServices?.filter((s: any) => s && s.title) || []
const leadMagnet = post.leadMagnetCTA
---
<BaseLayout
  title={post.seo?.metaTitle || post.title}
  description={post.seo?.metaDescription || post.excerpt}
  ogImage={post.heroImage?.url}
>
  <JsonLd slot="head" schema={[articleSchema, breadcrumbSchema]} />

  <article class="blog-article">
    <!-- Header -->
    <header class="blog-article__header">
      <div class="blog-article__header-inner">
        <div class="blog-article__meta">
          <span class="blog-article__category">{categoryLabels[post.category] || post.category}</span>
          <time class="blog-article__date" datetime={post.publishDate}>
            {new Date(post.publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        <h1 class="blog-article__title">{post.title}</h1>
        <p class="blog-article__excerpt">{post.excerpt}</p>
        <p class="blog-article__author">By {post.author || 'BaseScape'}</p>
      </div>
    </header>

    <!-- Hero Image -->
    {post.heroImage?.url && (
      <div class="blog-article__hero">
        <img
          src={post.heroImage.url}
          alt={post.heroImage.alt || post.title}
          width="1200"
          height="630"
          class="blog-article__hero-img"
        />
      </div>
    )}

    <!-- Content -->
    <div class="blog-article__body">
      <div class="blog-article__content" set:html={serializeLexical(post.content)} />

      <!-- Inline Lead Magnet CTA -->
      {leadMagnet && leadMagnet.title && (
        <LeadMagnetCTA
          title={leadMagnet.title}
          description={leadMagnet.description}
          ctaText={leadMagnet.ctaText}
          thumbnailUrl={leadMagnet.thumbnailImage?.url}
          leadMagnetId={leadMagnet.id}
          landingPageUrl={leadMagnet.slug ? `/guides/${leadMagnet.slug}` : undefined}
        />
      )}

      <!-- Related Services -->
      {relatedServices.length > 0 && (
        <div class="blog-article__related">
          <h3 class="blog-article__related-heading">Related Services</h3>
          <div class="blog-article__related-links">
            {relatedServices.map((service: any) => (
              <a href={`/services/${service.slug}`} class="blog-article__related-link">
                {service.title} &rarr;
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- CTA -->
    <div class="blog-article__cta">
      <CTABlock
        headline="Ready to start your project?"
        phone={phone}
        variant="section"
      />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article__header {
    background: var(--color-bgAlt);
    padding: var(--size-8) 0 var(--size-6);
  }

  .blog-article__header-inner {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  @media (min-width: 768px) {
    .blog-article__header {
      padding: var(--size-10) 0 var(--size-7);
    }
    .blog-article__header-inner {
      padding-inline: var(--size-6);
    }
  }

  .blog-article__meta {
    display: flex;
    align-items: center;
    gap: var(--size-3);
    margin-bottom: var(--size-3);
  }

  .blog-article__category {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal500);
  }

  .blog-article__date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-textMuted);
  }

  .blog-article__title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    line-height: 1.15;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-3);
  }

  .blog-article__excerpt {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 0.5vw + 0.875rem, 1.1875rem);
    line-height: 1.6;
    color: var(--color-textBody);
    margin-bottom: var(--size-3);
  }

  .blog-article__author {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-textMuted);
  }

  .blog-article__hero {
    max-width: 1000px;
    margin-inline: auto;
    padding-inline: var(--size-4);
    margin-top: calc(-1 * var(--size-4));
  }

  @media (min-width: 768px) {
    .blog-article__hero {
      padding-inline: var(--size-6);
    }
  }

  .blog-article__hero-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .blog-article__body {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--size-7) var(--size-4);
  }

  @media (min-width: 768px) {
    .blog-article__body {
      padding: var(--size-9) var(--size-6);
    }
  }

  .blog-article__content {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-textBody);
  }

  .blog-article__content :global(h2) {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: 1.625rem;
    line-height: 1.2;
    color: var(--color-textPrimary);
    margin-top: var(--size-8);
    margin-bottom: var(--size-3);
  }

  .blog-article__content :global(h3) {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-textPrimary);
    margin-top: var(--size-6);
    margin-bottom: var(--size-2);
  }

  .blog-article__content :global(p) {
    margin-bottom: var(--size-4);
  }

  .blog-article__content :global(ul),
  .blog-article__content :global(ol) {
    margin-bottom: var(--size-4);
    padding-left: var(--size-6);
  }

  .blog-article__content :global(li) {
    margin-bottom: var(--size-2);
  }

  .blog-article__content :global(a) {
    color: var(--color-navy600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-article__content :global(a:hover) {
    color: var(--color-navy500, var(--color-navy600));
  }

  .blog-article__content :global(blockquote) {
    border-left: 3px solid var(--color-green500);
    padding-left: var(--size-4);
    margin: var(--size-5) 0;
    font-style: italic;
    color: var(--color-textMuted);
  }

  .blog-article__related {
    margin-top: var(--size-8);
    padding-top: var(--size-6);
    border-top: 1px solid var(--color-border);
  }

  .blog-article__related-heading {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-3);
  }

  .blog-article__related-links {
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .blog-article__related-link {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-navy600);
    text-decoration: none;
  }

  .blog-article__related-link:hover {
    text-decoration: underline;
  }

  .blog-article__cta {
    max-width: 800px;
    margin-inline: auto;
    padding: 0 var(--size-4) var(--size-10);
  }
</style>
