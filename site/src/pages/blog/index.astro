---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CTABlock from '../../components/content/CTABlock.astro'
import { fetchBlogPosts, fetchSiteSettings } from '../../lib/payload'

let posts: any[] = []
let settings: any = {
  phone: '(888) 414-0007',
  businessName: 'BaseScape',
}

try {
  const [postsRes, siteSettings] = await Promise.all([
    fetchBlogPosts(),
    fetchSiteSettings(),
  ])
  posts = postsRes.docs || []
  settings = { ...settings, ...siteSettings }
} catch {}

const phone = settings.phone

const categoryLabels: Record<string, string> = {
  'walkout-basements': 'Walkout Basements',
  'egress-windows': 'Egress Windows',
  'basement-remodeling': 'Basement Remodeling',
  'retaining-walls': 'Retaining Walls',
  'adu-compliance': 'ADU Compliance',
  'financing': 'Financing',
  'local-guides': 'Local Guides',
  'safety': 'Safety',
}

const categories = [...new Set(posts.map((p: any) => p.category))].filter(Boolean)
---
<BaseLayout
  title="Blog"
  description="Expert advice on walkout basements, egress windows, ADU compliance, and financing from BaseScape — Utah's basement access specialists."
>
  <!-- Hero -->
  <section class="blog-hero">
    <div class="blog-hero__inner">
      <h1 class="blog-hero__title">Blog & Resources</h1>
      <p class="blog-hero__subtitle">
        Expert advice on basement access, egress compliance, financing, and Utah building regulations.
      </p>
    </div>
  </section>

  <!-- Category Nav -->
  {categories.length > 1 && (
    <nav class="blog-categories" aria-label="Blog categories">
      <div class="blog-categories__inner">
        <span class="blog-categories__label">Filter:</span>
        <span class="blog-categories__tag blog-categories__tag--active">All</span>
        {categories.map((cat: string) => (
          <span class="blog-categories__tag">{categoryLabels[cat] || cat}</span>
        ))}
      </div>
    </nav>
  )}

  <!-- Posts Grid -->
  <section class="blog-posts">
    <div class="blog-posts__inner">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post: any) => (
            <article class="blog-card">
              {post.heroImage?.url && (
                <a href={`/blog/${post.slug}`} class="blog-card__image-link">
                  <img
                    src={post.heroImage.url}
                    alt={post.heroImage.alt || post.title}
                    width="600"
                    height="340"
                    class="blog-card__image"
                  />
                </a>
              )}
              <div class="blog-card__content">
                <div class="blog-card__meta">
                  <span class="blog-card__category">{categoryLabels[post.category] || post.category}</span>
                  <time class="blog-card__date" datetime={post.publishDate}>
                    {new Date(post.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                <p class="blog-card__excerpt">{post.excerpt}</p>
                <a href={`/blog/${post.slug}`} class="blog-card__link">Read article &rarr;</a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="blog-empty">
          <p>Articles coming soon. Check back for expert guidance on basement access, egress compliance, and Utah building regulations.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="blog-cta">
    <div class="blog-cta__inner">
      <CTABlock
        headline="Ready to start your project?"
        phone={phone}
        variant="section"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: var(--color-bgAlt);
    padding: var(--size-8) 0;
  }

  .blog-hero__inner {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--size-4);
    text-align: center;
  }

  @media (min-width: 768px) {
    .blog-hero {
      padding: var(--size-10) 0;
    }
    .blog-hero__inner {
      padding-inline: var(--size-6);
    }
  }

  .blog-hero__title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    line-height: 1.1;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-3);
  }

  .blog-hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 0.5vw + 0.875rem, 1.1875rem);
    line-height: 1.6;
    color: var(--color-textBody);
  }

  .blog-categories {
    border-bottom: 1px solid var(--color-border);
    padding: var(--size-3) 0;
  }

  .blog-categories__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
    display: flex;
    align-items: center;
    gap: var(--size-2);
    flex-wrap: wrap;
  }

  .blog-categories__label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-textMuted);
  }

  .blog-categories__tag {
    display: inline-block;
    padding: var(--size-1) var(--size-3);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-textBody);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    cursor: default;
  }

  .blog-categories__tag--active {
    background: var(--color-navy600);
    color: white;
    border-color: var(--color-navy600);
  }

  .blog-posts {
    padding: var(--size-8) 0;
  }

  .blog-posts__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  @media (min-width: 768px) {
    .blog-posts {
      padding: var(--size-10) 0;
    }
    .blog-posts__inner {
      padding-inline: var(--size-6);
    }
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-6);
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-card {
    background: var(--color-bgSurface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.15s ease;
  }

  .blog-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .blog-card__image-link {
    display: block;
  }

  .blog-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .blog-card__content {
    padding: var(--size-4) var(--size-5);
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--size-3);
    margin-bottom: var(--size-2);
  }

  .blog-card__category {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-teal500);
  }

  .blog-card__date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-textMuted);
  }

  .blog-card__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.3;
    margin-bottom: var(--size-2);
  }

  .blog-card__title a {
    color: var(--color-textPrimary);
    text-decoration: none;
  }

  .blog-card__title a:hover {
    color: var(--color-navy600);
  }

  .blog-card__excerpt {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-textBody);
    margin-bottom: var(--size-3);
  }

  .blog-card__link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-navy600);
    text-decoration: none;
  }

  .blog-card__link:hover {
    text-decoration: underline;
  }

  .blog-empty {
    text-align: center;
    padding: var(--size-10) var(--size-4);
    color: var(--color-textMuted);
    font-family: var(--font-sans);
    font-size: 1rem;
  }

  .blog-cta {
    padding: var(--size-6) 0 var(--size-10);
  }

  .blog-cta__inner {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }
</style>
