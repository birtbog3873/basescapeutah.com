---
import { fetchNavigation, fetchSiteSettings } from '../../lib/payload'

let settings: any = {
  businessName: 'BaseScape',
  phone: '(801) 919-8224',
  email: 'hello@basescapeutah.com',
  address: { street: '123 Innovation Way', city: 'Draper', state: 'UT', zip: '84020' },
  licenseNumber: '14082066-5501 B100',
  insuranceInfo: 'Fully Insured & Bonded — General Liability',
  socialLinks: {},
}
let footerNav: any[] = []

try {
  const [nav, siteSettings] = await Promise.all([
    fetchNavigation(),
    fetchSiteSettings(),
  ])
  footerNav = nav?.footerNav || []
  settings = { ...settings, ...siteSettings }
} catch {
  footerNav = [
    { heading: 'Services', links: [
      { label: 'Walkout Basements', url: '/services/walkout-basements' },
      { label: 'Basement Remodeling', url: '/services/basement-remodeling' },
      { label: 'Pavers & Hardscapes', url: '/services/pavers-hardscapes' },
      { label: 'Retaining Walls', url: '/services/retaining-walls' },
      { label: 'Artificial Turf', url: '/services/artificial-turf' },
      { label: 'Egress Windows', url: '/services/egress-windows' },
    ]},
    { heading: 'Company', links: [
      { label: 'About', url: '/about' },
      { label: 'How It Works', url: '/how-it-works' },
      { label: 'FAQ', url: '/faq' },
    ]},
    { heading: 'Resources', links: [
      { label: 'Financing', url: '/financing' },
      { label: 'Blog', url: '/blog' },
      { label: 'Privacy Policy', url: '/privacy' },
    ]},
  ]
}

// Filter Gallery links from footer nav when hidden
if (!settings.showGallery) {
  footerNav = footerNav.map((column: any) => ({
    ...column,
    links: column.links?.filter((link: any) => link.url !== '/gallery') || [],
  }))
}

const currentYear = new Date().getFullYear()
---
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="BaseScape — Home">
          <span class="footer__logo-base">Base</span><span class="footer__logo-scape">Scape</span>
        </a>
        <p class="footer__tagline">
          Walkout Entries &middot; Daylight Windows &middot; Egress
        </p>
        <address class="footer__address">
          <p>{settings.address.street}</p>
          <p>{settings.address.city}, {settings.address.state} {settings.address.zip}</p>
          <p>
            <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`}>{settings.phone}</a>
          </p>
          <p>
            <a href={`mailto:${settings.email}`}>{settings.email}</a>
          </p>
        </address>
      </div>

      <!-- Navigation columns -->
      {footerNav.map((column: any) => (
        <div class="footer__column">
          <h3 class="footer__column-heading">{column.heading}</h3>
          <ul class="footer__column-list" role="list">
            {column.links.map((link: any) => (
              <li>
                <a href={link.url} class="footer__link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <div class="footer__credentials">
        <span>License #{settings.licenseNumber}</span>
        <span class="footer__separator">&middot;</span>
        <span>{settings.insuranceInfo}</span>
      </div>
      <p class="footer__copyright">
        &copy; {currentYear} {settings.businessName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy700);
    color: var(--color-navy200);
    padding: var(--size-9) 0 var(--size-5);
  }

  .footer__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--size-4);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-7);
    padding-bottom: var(--size-7);
    border-bottom: 1px solid var(--color-navy600);
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__top {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
  }

  .footer__logo {
    display: inline-block;
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: var(--size-3);
  }

  .footer__logo-base { color: var(--color-navy100); }
  .footer__logo-scape { color: var(--color-green400); }

  .footer__tagline {
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-navy300);
    margin-bottom: var(--size-4);
  }

  .footer__address {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .footer__address a {
    color: white;
    text-decoration: none;
  }

  .footer__address a:hover {
    color: white;
  }

  .footer__column-heading {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: white;
    letter-spacing: 0.03em;
    margin-bottom: var(--size-3);
  }

  .footer__column-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .footer__link {
    font-size: 0.9375rem;
    color: var(--color-navy200);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer__link:hover {
    color: white;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
    padding-top: var(--size-5);
    font-size: 0.8125rem;
    color: var(--color-navy300);
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer__credentials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-1);
  }

  .footer__separator {
    color: var(--color-navy400);
  }
</style>
