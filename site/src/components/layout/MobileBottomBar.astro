---
import { fetchSiteSettings } from '../../lib/payload'

interface Props {
  hideEstimate?: boolean
  estimateLabel?: string
  estimateHref?: string
}

const { hideEstimate = false, estimateLabel = 'Free Estimate', estimateHref = '/contact' } = Astro.props

let phone = '(888) 414-0007'

try {
  const settings = await fetchSiteSettings()
  phone = settings?.phone || phone
} catch {
  // Use fallback
}
---
<nav class={`mobile-bar ${hideEstimate ? 'mobile-bar--single' : ''}`} aria-label="Quick actions">
  <a
    href={`tel:${phone.replace(/[^\d+]/g, '')}`}
    class="mobile-bar__btn mobile-bar__btn--call"
    aria-label={`Call Now — ${phone}`}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Call Now
  </a>
  {!hideEstimate && (
    <a
      href={estimateHref}
      class="mobile-bar__btn mobile-bar__btn--estimate"
    >
      {estimateLabel}
    </a>
  )}
</nav>

<style>
  .mobile-bar {
    display: flex;
    flex-shrink: 0;
    z-index: 40;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  @media (min-width: 1024px) {
    .mobile-bar { display: none; }
  }

  .mobile-bar__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--size-2);
    flex: 1;
    min-height: 52px;
    padding: var(--size-3) var(--size-3);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .mobile-bar__btn:hover {
    opacity: 0.9;
  }

  .mobile-bar__btn--call {
    background: var(--color-ctaSecondaryBg, #1B3B5E);
    color: var(--color-ctaSecondaryText, #fff);
  }

  .mobile-bar__btn--estimate {
    background: var(--color-ctaPrimaryBg, #946106);
    color: var(--color-ctaPrimaryText, #fff);
  }
</style>
