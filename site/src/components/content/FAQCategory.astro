---
interface Props {
  label: string
  id?: string
}

const { label, id } = Astro.props
---
<details class="faq-category" id={id}>
  <summary class="faq-category__header">
    <span class="faq-category__label">{label}</span>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-category__chevron" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </summary>
  <div class="faq-category__content">
    <slot>
      <p class="faq-category__empty">No questions available yet.</p>
    </slot>
  </div>
</details>

<style>
  .faq-category {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bgPage);
  }

  .faq-category__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-3);
    padding: var(--size-4) var(--size-5);
    background: var(--color-bgAlt);
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: clamp(1.125rem, 1vw + 0.75rem, 1.375rem);
    line-height: 1.3;
    color: var(--color-navy700);
    cursor: pointer;
    list-style: none;
    transition: background 0.15s ease;
    min-height: 48px;
  }

  .faq-category__header::-webkit-details-marker {
    display: none;
  }

  .faq-category__header:hover {
    background: var(--color-navy50, var(--color-bgAlt));
  }

  .faq-category__chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: var(--color-textMuted);
  }

  .faq-category[open] .faq-category__chevron {
    transform: rotate(180deg);
  }

  .faq-category__content {
    padding: var(--size-4) var(--size-5);
  }

  .faq-category__empty {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-textMuted);
    padding: var(--size-2) 0;
  }

  @media (max-width: 767px) {
    .faq-category__header {
      padding: var(--size-3) var(--size-4);
    }

    .faq-category__content {
      padding: var(--size-3) var(--size-3);
    }
  }
</style>
