---
interface Props {
  headline?: string
  phone?: string
  estimateUrl?: string
  variant?: 'default' | 'hero' | 'section'
}

const {
  headline = 'Ready to Transform Your Basement?',
  phone = '(801) 919-8224',
  estimateUrl = '/contact',
  variant = 'default',
} = Astro.props

const phoneClean = phone.replace(/[^\d+]/g, '')
---
<div class={`cta-block cta-block--${variant}`}>
  {headline && (
    <p class="cta-block__headline">{headline}</p>
  )}
  <div class="cta-block__actions">
    <a href={`tel:${phoneClean}`} class="cta-block__btn cta-block__btn--call plausible-event-name=Call+Click" aria-label={`Call ${phone}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {phone}
    </a>
    <a href={estimateUrl} class="cta-block__btn cta-block__btn--estimate">
      Book Appointment
    </a>
  </div>
</div>

<style>
  .cta-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--size-4);
    text-align: center;
    padding: var(--size-6);
  }

  .cta-block--hero {
    padding: 0;
    align-items: flex-start;
    text-align: left;
  }

  .cta-block--section {
    background: var(--color-bgAlt);
    border-radius: var(--radius-lg);
    padding: var(--size-8) var(--size-6);
  }

  .cta-block__headline {
    font-family: var(--font-serif);
    font-weight: 700;
    font-variation-settings: "WONK" 0, "SOFT" 100;
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    line-height: 1.2;
    color: var(--color-textPrimary);
  }

  .cta-block__actions {
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
    width: 100%;
    max-width: 400px;
  }

  @media (min-width: 480px) {
    .cta-block__actions {
      flex-direction: row;
    }

    .cta-block--hero .cta-block__actions {
      max-width: none;
    }
  }

  .cta-block__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--size-2);
    padding: var(--size-3) var(--size-5);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.15s ease;
    min-height: 48px;
    flex: 1;
  }

  .cta-block__btn--call {
    background: var(--color-ctaSecondaryBg);
    color: var(--color-ctaSecondaryText);
    white-space: nowrap;
  }

  .cta-block__btn--call:hover {
    background: var(--color-ctaSecondaryHover);
    color: var(--color-ctaSecondaryText);
  }

  .cta-block__btn--estimate {
    background: var(--color-ctaPrimaryBg);
    color: var(--color-ctaPrimaryText);
  }

  .cta-block__btn--estimate:hover {
    background: var(--color-ctaPrimaryHover);
    color: var(--color-ctaPrimaryText);
  }
</style>
