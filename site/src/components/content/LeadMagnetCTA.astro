---
interface Props {
  title: string
  description: string
  ctaText?: string
  thumbnailUrl?: string
  leadMagnetId: string
  landingPageUrl?: string
}

const {
  title,
  description,
  ctaText = 'Download Free Guide',
  thumbnailUrl,
  leadMagnetId,
  landingPageUrl,
} = Astro.props

const href = landingPageUrl || `#lead-magnet-${leadMagnetId}`
---
<div class="lead-magnet-cta">
  {thumbnailUrl && (
    <div class="lead-magnet-cta__thumb">
      <img src={thumbnailUrl} alt={title} loading="lazy" decoding="async" width="200" height="260" />
    </div>
  )}
  <div class="lead-magnet-cta__content">
    <span class="lead-magnet-cta__overline">Free Resource</span>
    <h3 class="lead-magnet-cta__title">{title}</h3>
    <p class="lead-magnet-cta__desc">{description}</p>
    <a href={href} class="lead-magnet-cta__btn" data-lead-magnet-id={leadMagnetId}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      {ctaText}
    </a>
  </div>
</div>

<style>
  .lead-magnet-cta {
    display: flex;
    flex-direction: column;
    gap: var(--size-4);
    padding: var(--size-5);
    background: linear-gradient(135deg, var(--color-navy50) 0%, var(--color-bgSurface) 100%);
    border: 1px solid var(--color-navy200);
    border-radius: var(--radius-lg);
    margin: var(--size-6) 0;
  }

  @media (min-width: 480px) {
    .lead-magnet-cta {
      flex-direction: row;
      align-items: center;
    }
  }

  .lead-magnet-cta__thumb {
    flex-shrink: 0;
    width: 120px;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .lead-magnet-cta__thumb img {
    width: 100%;
    height: auto;
    display: block;
  }

  .lead-magnet-cta__overline {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal500);
    margin-bottom: var(--size-1);
  }

  .lead-magnet-cta__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-textPrimary);
    margin-bottom: var(--size-2);
  }

  .lead-magnet-cta__desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-textBody);
    margin-bottom: var(--size-3);
  }

  .lead-magnet-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
    padding: var(--size-2) var(--size-4);
    background: var(--color-ctaPrimaryBg);
    color: var(--color-ctaPrimaryText);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.15s ease;
    min-height: 44px;
  }

  .lead-magnet-cta__btn:hover {
    background: var(--color-ctaPrimaryHover);
  }
</style>
