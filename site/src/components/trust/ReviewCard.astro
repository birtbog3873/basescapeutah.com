---
interface Props {
  reviewerName: string
  reviewText: string
  starRating: number
  city?: string
  source: string
}

const { reviewerName, reviewText, starRating, city, source } = Astro.props
const stars = Array.from({ length: 5 }, (_, i) => i < starRating)
---
<div class="review-card">
  <div class="review-card__stars" role="img" aria-label={`${starRating} out of 5 stars`}>
    {stars.map((filled) => (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill={filled ? 'currentColor' : 'none'}
        stroke="currentColor"
        stroke-width="2"
        class={`review-card__star ${filled ? 'review-card__star--filled' : ''}`}
        aria-hidden="true"
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>
  <blockquote class="review-card__text">
    &ldquo;{reviewText}&rdquo;
  </blockquote>
  <div class="review-card__footer">
    <span class="review-card__name">{reviewerName}</span>
    {city && <span class="review-card__city">{city}</span>}
    <span class="review-card__source">{source}</span>
  </div>
</div>

<style>
  .review-card {
    background: var(--color-bgSurface);
    border-radius: var(--radius-md);
    padding: var(--size-5);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
  }

  .review-card__star {
    color: var(--color-slate300);
  }

  .review-card__star--filled {
    color: var(--color-amber500);
  }

  .review-card__text {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-variation-settings: "WONK" 1, "SOFT" 50;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--color-navy600);
    flex: 1;
  }

  .review-card__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--size-2);
    padding-top: var(--size-2);
    border-top: 1px solid var(--color-border);
  }

  .review-card__name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-navy600);
  }

  .review-card__city {
    font-size: 0.875rem;
    color: var(--color-textMuted);
  }

  .review-card__source {
    font-size: 0.8125rem;
    color: var(--color-textMuted);
    margin-left: auto;
  }
</style>
