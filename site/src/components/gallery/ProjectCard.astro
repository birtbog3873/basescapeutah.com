---
interface Props {
  title: string
  slug: string
  projectType?: string
  city?: string
  thumbnail?: { url: string; alt: string }
  challenge?: string
}

const { title, slug, projectType, city, thumbnail, challenge } = Astro.props
---
<a href={`/gallery#${slug}`} class="project-card">
  <div class="project-card__image">
    {thumbnail ? (
      <img src={thumbnail.url} alt={thumbnail.alt} loading="lazy" decoding="async" width="600" height="400" />
    ) : (
      <div class="project-card__placeholder" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    )}
  </div>
  <div class="project-card__body">
    <div class="project-card__meta">
      {projectType && <span class="project-card__type">{projectType}</span>}
      {city && <span class="project-card__city">{city}</span>}
    </div>
    <h3 class="project-card__title">{title}</h3>
    {challenge && (
      <p class="project-card__excerpt">{challenge}</p>
    )}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bgSurface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: box-shadow 0.2s ease;
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
  }

  .project-card__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bgAlt);
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-navy300);
  }

  .project-card__body {
    padding: var(--size-3) var(--size-4) var(--size-4);
    display: flex;
    flex-direction: column;
    gap: var(--size-1);
  }

  .project-card__meta {
    display: flex;
    gap: var(--size-2);
    font-size: 0.75rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .project-card__type {
    color: var(--color-green600);
    font-weight: 500;
  }

  .project-card__city {
    color: var(--color-textMuted);
  }

  .project-card__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-textPrimary);
    line-height: 1.3;
  }

  .project-card__excerpt {
    font-size: 0.875rem;
    color: var(--color-textBody);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
